# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Built APKs / IPAs shipped to devices — kept out of git so we don't
# bloat the repo. The build folder is source-of-truth; releases/ is
# just a local staging area for side-loading.
releases/
*.apk
*.aab

# Android release signing — the keystore and its credentials must
# never be committed. If either is lost, upgrades from this signing
# identity are impossible; treat like a private key.
android/key.properties
android/upload-keystore.jks
android/*.jks
android/*.keystore

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment files (contain secrets — never commit)
.env
!.env.example

